@inproceedings{martinez3DPrintedHaptic2016,
  title = {3-{{D}} Printed Haptic Devices for Educational Applications},
  booktitle = {2016 {{IEEE Haptics Symposium}} ({{HAPTICS}})},
  author = {Martinez, Melisa Orta and Morimoto, Tania K. and Taylor, Annalisa T. and Barron, Aaron C. and Pultorak, J. D. Akzl and Wang, Jeanny and Calasanz-Kaiser, Agnes and Davis, Richard Lee and Blikstein, Paulo and Okamura, Allison M.},
  date = {2016-04},
  pages = {126--133},
  issn = {2324-7355},
  doi = {10.1109/HAPTICS.2016.7463166},
  url = {https://ieeexplore.ieee.org/document/7463166},
  urldate = {2026-04-16},
  abstract = {Haptic technology has the potential to expand and transform the ways that students can experience a variety of science, technology, engineering, and math (STEM) topics. Designing kinesthetic haptic devices for educational applications is challenging because of the competing objectives of using low-cost components, making the device robust enough to be handled by students, and the desire to render high fidelity haptic virtual environments. In this paper, we present the evolution of a device called "Hapkit": a low cost, one-degree-of-freedom haptic kit that can be assembled by students. From 2013–2015, different versions of Hapkit were used in courses as a tool to teach haptics, physics, and control. These include a Massive Open Online Course (MOOC), two undergraduate courses, a graduate course, and a middle school class. Based on our experience using Hapkit in these educational environments, we evolved the design in terms of its structural materials, drive mechanism, and mechatronic components. Our latest design, Hapkit 3.0, includes several features that allow students to manufacture and assemble a robust and high-fidelity haptic device. First, it uses 3-D printed plastic structural material, which allows the design to be built and customized using readily available tools. Second, the design takes into account the limitations of 3-D printing, such as warping during printing and poor tolerances. This is achieved at a materials cost of approximately US \$50, which makes it feasible for distribution in classroom and online education settings. The open source design is available at http://hapkit.stanford.edu.},
  eventtitle = {2016 {{IEEE Haptics Symposium}} ({{HAPTICS}})},
  keywords = {Education,Friction,Haptic interfaces,Kinematics,Performance evaluation,Robustness,Wheels},
  file = {C:\Users\tman0\Zotero\storage\F7RCZG2M\Martinez et al. - 2016 - 3-D printed haptic devices for educational applications.pdf}
}

@inproceedings{martinezOpenSourceModular2017,
  title = {Open Source, Modular, Customizable, 3-{{D}} Printed Kinesthetic Haptic Devices},
  booktitle = {2017 {{IEEE World Haptics Conference}} ({{WHC}})},
  author = {Martinez, Melisa Orta and Campion, Joseph and Gholami, Tara and Rittikaidachar, Michal K. and Barron, Aaron C. and Okamura, Allison M.},
  date = {2017-06},
