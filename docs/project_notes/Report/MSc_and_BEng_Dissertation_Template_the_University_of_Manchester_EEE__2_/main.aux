\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces  Distribution of matched host-side end-to-end latency, measured from state-packet parsing to completion of torque command transmission. The latency is concentrated at low values, with prominent peaks near 0~ms and around 0.5~ms, and only a small number of higher-latency outliers. }}{34}{figure.caption.15}\protected@file@percent }
\newlabel{fig:e2e_hist}{{9}{34}{Distribution of matched host-side end-to-end latency, measured from state-packet parsing to completion of torque command transmission. The latency is concentrated at low values, with prominent peaks near 0~ms and around 0.5~ms, and only a small number of higher-latency outliers}{figure.caption.15}{}}
