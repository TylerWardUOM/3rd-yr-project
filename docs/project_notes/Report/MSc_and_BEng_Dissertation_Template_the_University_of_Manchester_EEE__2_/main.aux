\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces  Cumulative distribution functions of measured round-trip latency for nominal ping intervals of 1~ms, 2~ms, and 10~ms. The distributions overlap closely and rise sharply at approximately 15--16~ms, indicating that round-trip latency is dominated by a largely fixed delay component rather than by the selected ping interval. }}{21}{figure.caption.12}\protected@file@percent }
\newlabel{fig:rtt_cdf}{{7}{21}{Cumulative distribution functions of measured round-trip latency for nominal ping intervals of 1~ms, 2~ms, and 10~ms. The distributions overlap closely and rise sharply at approximately 15--16~ms, indicating that round-trip latency is dominated by a largely fixed delay component rather than by the selected ping interval}{figure.caption.12}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces  Distribution of matched host-side end-to-end latency, measured from state-packet parsing to completion of torque command transmission. The latency is concentrated at low values, with prominent peaks near 0~ms and around 0.5~ms, and only a small number of higher-latency outliers. }}{22}{figure.caption.13}\protected@file@percent }
\newlabel{fig:e2e_hist}{{8}{22}{Distribution of matched host-side end-to-end latency, measured from state-packet parsing to completion of torque command transmission. The latency is concentrated at low values, with prominent peaks near 0~ms and around 0.5~ms, and only a small number of higher-latency outliers}{figure.caption.13}{}}
